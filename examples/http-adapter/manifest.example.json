{
  "version": "1",
  "health_path": "/healthz",
  "health_auth": "none",
  "operations": [
    {
      "upstream_name": "get-order",
      "name": "Get order",
      "description": "Returns one order by ID.",
      "method": "GET",
      "path": "/v1/orders",
      "input_schema": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" }
        }
      },
      "output_schema": { "type": "object" },
      "tags": ["orders", "read"],
      "examples": ["Get order ord_123"],
      "auth": "bearer",
      "requires_approval": "never"
    },
    {
      "upstream_name": "create-order",
      "name": "Create order",
      "description": "Creates an order from structured JSON input.",
      "method": "POST",
      "path": "/v1/orders",
      "input_schema": {
        "type": "object",
        "required": ["customer_id"],
        "properties": {
          "customer_id": { "type": "string" }
        }
      },
      "output_schema": { "type": "object" },
      "tags": ["orders", "write"],
      "auth": "bearer",
      "requires_approval": "always"
    }
  ]
}
